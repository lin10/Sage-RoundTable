# Sage-RoundTable 环境变量配置示例
# 复制此文件为 .env 并填入你的 API Keys

# ==================== OpenAI ====================
# 获取地址: https://platform.openai.com/api-keys
OPENAI_API_KEY=sk-your-openai-api-key-here

# OpenAI API Base URL (可选，用于代理或兼容API)
# OPENAI_BASE_URL=https://api.openai.com/v1

# ==================== 阿里云通义千问 ====================
# 获取地址: https://dashscope.console.aliyun.com/apiKey
QWEN_API_KEY=sk-your-qwen-api-key-here

# ==================== 百度文心一言 ====================
# 获取地址: https://console.bce.baidu.com/qianfan/ais/console/applicationConsole/application
WENXIN_API_KEY=your-wenxin-api-key-here
WENXIN_SECRET_KEY=your-wenxin-secret-key-here

# ==================== 智谱AI ====================
# 获取地址: https://open.bigmodel.cn/usercenter/apikeys
ZHIPU_API_KEY=your-zhipu-api-key-here

# ==================== DeepSeek ====================
# 获取地址: https://platform.deepseek.com/api_keys
DEEPSEEK_API_KEY=sk-your-deepseek-api-key-here

# ==================== Claude (Anthropic) ====================
# 获取地址: https://console.anthropic.com/settings/keys
# CLAUDE_API_KEY=sk-ant-your-claude-api-key-here

# ==================== Google Gemini ====================
# 获取地址: https://makersuite.google.com/app/apikey
# GEMINI_API_KEY=your-gemini-api-key-here

# ==================== 其他配置 ====================
# 日志级别: debug, info, warn, error
LOG_LEVEL=info

# 日志格式: text, json
LOG_FORMAT=text

# ==================== 服务器配置 ====================
# 服务器端口
SERVER_PORT=8080

# 数据库路径
DB_PATH=./data/sage_roundtable.db

# 缓存 TTL (秒)
CACHE_TTL=3600

# 速率限制 (每分钟请求数)
RATE_LIMIT=60
